{
  "name": "command-centre",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "description": "Multi-agent observability command centre — Bun + Hono + bun:sqlite + Svelte 5",
  "scripts": {
    "start": "bun run scripts/server.ts",
    "test": "bun test scripts",
    "typecheck": "tsc --noEmit",
    "check": "tsc --noEmit && bun test scripts && cd ui && bun run check",
    "dev": "bun run --watch scripts/server.ts",
    "doctor": "bun run scripts/doctor.ts",
    "sync": "bun run scripts/sync_agents.ts --once",
    "setup:otel": "bun run scripts/setup_otel.ts",
    "build:ui": "cd ui && bun install && bun run build",
    "dev:ui": "cd ui && bun run dev"
  },
  "dependencies": {
    "hono": "^4.6.14",
    "yaml": "^2.6.1"
  },
  "devDependencies": {
    "@types/bun": "^1.1.14",
    "typescript": "^5.7.2"
  }
}
